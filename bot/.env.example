# Telegram bot token from @BotFather (required)
BOT_TOKEN=123456:ABCDEF

# Async SQLAlchemy URL. Default is SQLite in ./data/app.db
DATABASE_URL=sqlite+aiosqlite:///./data/app.db

# Local API server (FastAPI)
API_HOST=127.0.0.1
API_PORT=8000

# Public HTTPS URL of the Mini App (the page bot button opens)
# Examples:
#   https://your-tunnel.trycloudflare.com
#   https://clientika.app
WEBAPP_URL=

# Optional outbound proxy for Telegram API (HTTP/SOCKS)
# TELEGRAM_PROXY_URL=socks5://127.0.0.1:1080
TELEGRAM_PROXY_URL=

# Reminder scheduler tick (seconds)
SCHEDULER_INTERVAL_SECONDS=60

# Default working day boundaries (24h format, master-local time)
DEFAULT_WORK_START=10:00
DEFAULT_WORK_END=20:00
DEFAULT_SLOT_STEP_MINUTES=30

# Default master timezone (IANA name).
DEFAULT_TIMEZONE=Europe/Moscow

# Comma-separated Telegram user IDs for admin panel access
ADMIN_TG_USER_IDS=
